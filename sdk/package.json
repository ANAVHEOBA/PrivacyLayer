{
  "name": "@privacylayer/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for PrivacyLayer shielded pool on Stellar",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:smoke": "jest zk_smoke.test.ts --verbose",
    "test:schema-parity": "jest schema_parity.test.ts --verbose",
    "test:zk-106": "jest hash_mode.test.ts proof_abstraction.test.ts --verbose",
    "test:zk-107": "jest zk_smoke.test.ts --verbose",
    "test:zk-108": "jest schema_parity.test.ts --verbose",
    "test:harness": "jest test/harness --verbose",
    "test:harness:fast": "BACKEND_TYPE=mock TIMEOUT_MS=5000 JEST_TIMEOUT=10000 jest test/harness --verbose",
    "test:harness:comprehensive": "BACKEND_TYPE=real TIMEOUT_MS=60000 JEST_TIMEOUT=120000 jest test/harness --verbose",
    "test:harness:ci": "CI=true BACKEND_TYPE=mock TIMEOUT_MS=5000 JEST_TIMEOUT=10000 jest test/harness --ci --coverage=false",
    "test:harness:ci:comprehensive": "CI=true BACKEND_TYPE=real TIMEOUT_MS=60000 JEST_TIMEOUT=120000 jest test/harness --ci --coverage=false"
  },
  "dependencies": {
    "@stellar/stellar-base": "^12.1.1",
    "@stellar/stellar-sdk": "^12.0.0",
    "@zkpassport/poseidon2": "^0.6.2",
    "bn.js": "^5.2.1",
    "elliptic": "^6.5.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
